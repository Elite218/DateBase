<script>
'use strict';

// ── STORAGE ───────────────────────────────────────────────────────────
var PKEY = 'politie_personen_v3';
var ZKEY = 'politie_zaken_v3';

function loadDB()  { try { return JSON.parse(localStorage.getItem(PKEY)||'[]'); } catch(e) { return []; } }
function loadZDB() { try { return JSON.parse(localStorage.getItem(ZKEY)||'[]'); } catch(e) { return []; } }
function saveDB()  { try { localStorage.setItem(PKEY, JSON.stringify(db)); } catch(e) { alert('Opslaan mislukt!'); } }
function saveZDB() { try { localStorage.setItem(ZKEY, JSON.stringify(zdb)); } catch(e) { alert('Opslaan mislukt!'); } }

var db  = loadDB();
var zdb = loadZDB();

var activeId      = null;
var activeZaakId  = null;
var activePid     = null;   // voor record/naam/rij/plaat/status modals
var confirmCb     = null;
var activeTab     = 'personen';
var searchMode    = 'naam';  // 'naam' of 'plaat'
var lastQuery     = '';

// ── HELPERS ───────────────────────────────────────────────────────────
function uid(prefix) { return (prefix||'X') + Date.now().toString(36).toUpperCase() + Math.random().toString(36).slice(2,5).toUpperCase(); }
function today()  { return new Date().toISOString().split('T')[0]; }
function fDate(d) { return d ? new Date(d).toLocaleDateString('nl-NL') : '—'; }
function initials(n) { return String(n).split(' ').map(function(w){ return w[0]||''; }).join('').slice(0,2).toUpperCase(); }
function findP(id) { for(var i=0;i<db.length;i++) { if(db[i].id===id) return db[i]; } return null; }
function findZ(id) { for(var i=0;i<zdb.length;i++) { if(zdb[i].id===id) return zdb[i]; } return null; }

function esc(s) {
  return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');
}

// ── KLOK ──────────────────────────────────────────────────────────────
(function tick() {
  var el = document.getElementById('klok');
