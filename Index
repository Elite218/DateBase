}
function doPlaat() {
  var p=findP(activePid); if(!p) return;
  p.nummerplaat=document.getElementById('pPlaat').value.trim().toUpperCase()||null;
  saveDB(); closeM('mPlaat'); refreshAll();
  if(activeId===activePid) showDossier(buildDossier(p));
}

// ── PERSOON VERWIJDEREN ───────────────────────────────────────────────
function doVerwijder(id) {
  var p=findP(id); if(!p) return;
  askConfirm('"'+p.naam+'" definitief verwijderen?', function(){
    // Verwijder ook uit zaken
    zdb.forEach(function(z){ z.betrokkenen=(z.betrokkenen||[]).filter(function(pid){ return pid!==id; }); });
    db=db.filter(function(x){ return x.id!==id; });
    activeId=null; saveDB(); saveZDB(); refreshAll();
    document.getElementById('emptyState').style.display='';
    document.getElementById('dossierWrap').style.display='none';
  });
}

// ── ZAKEN ─────────────────────────────────────────────────────────────
function renderBetrokkenenList(elId, selected) {
  var el=document.getElementById(elId); if(!el) return;
  if(!db.length){ el.innerHTML='<div style="font-family:DM Mono,monospace;font-size:.62rem;color:var(--t3);padding:8px">Geen personen in database</div>'; return; }
  el.innerHTML = db.map(function(p) {
    var checked = selected.indexOf(p.id)!==-1 ? ' checked' : '';
    return '<label class="betrokkene-opt">'
      +'<input type="checkbox" value="'+p.id+'"'+checked+'>'
      +'<span>'+esc(p.naam)+'</span>'
      +'<span style="font-family:DM Mono,monospace;font-size:.6rem;color:var(--t3)">'+p.id+'</span>'
      +'</label>';
  }).join('');
}

function getBetrokkenenSelected(elId) {
  var el=document.getElementById(elId); if(!el) return [];
  return Array.from(el.querySelectorAll('input[type=checkbox]:checked')).map(function(c){ return c.value; });
}

function doZaak() {
  var titel=document.getElementById('zTitel').value.trim();
  if(!titel){ document.getElementById('zTitelW').style.display='block'; return; }
  document.getElementById('zTitelW').style.display='none';
  var z = {
    id: uid('Z'),
    titel: titel,
    type: document.getElementById('zType').value,
    status: document.getElementById('zStatus').value,
    omschrijving: document.getElementById('zOmschrijving').value.trim(),
    betrokkenen: getBetrokkenenSelected('betrokkenenList'),
    aangemaakt: today()
  };
  zdb.push(z); saveZDB(); closeM('mZaak'); refreshAll();
  activeTab='zaken'; selectZaak(z.id);
}

function openZaakEdit(id) {
  var z=findZ(id); if(!z) return;
  activePid=id; // reuse activePid for zaak id
  document.getElementById('zeTitle').value=z.titel;
  document.getElementById('zeType').value=z.type||'misdrijf';
  document.getElementById('zeStatus').value=z.status||'open';
  document.getElementById('zeOmschrijving').value=z.omschrijving||'';
  renderBetrokkenenList('betrokkenenEditList', z.betrokkenen||[]);
  document.getElementById('mZaakEdit').classList.add('open');
}

function doZaakEdit() {
  var titel=document.getElementById('zeTitle').value.trim();
  if(!titel){ return; }
  var z=findZ(activePid); if(!z) return;
  z.titel=titel;
  z.type=document.getElementById('zeType').value;
  z.status=document.getElementById('zeStatus').value;
  z.omschrijving=document.getElementById('zeOmschrijving').value.trim();
  z.betrokkenen=getBetrokkenenSelected('betrokkenenEditList');
  saveZDB(); closeM('mZaakEdit'); refreshAll();
  activeZaakId=z.id; showDossier(buildZaakDossier(z));
}

function doVerwijderZaak(id) {
  var z=findZ(id); if(!z) return;
  askConfirm('Zaak "'+z.titel+'" definitief verwijderen?', function(){
    zdb=zdb.filter(function(x){ return x.id!==id; });
    activeZaakId=null; saveZDB(); refreshAll();
    document.getElementById('emptyState').style.display='';
    document.getElementById('dossierWrap').style.display='none';
  });
}

// ── MOBILE ────────────────────────────────────────────────────────────
function toggleDrawer() {
  var d=document.getElementById('mob-drawer'), b=document.getElementById('mob-backdrop');
  var open=d.classList.contains('open');
  if(open){ d.classList.remove('open'); b.classList.remove('open'); }
  else    { d.classList.add('open');    b.classList.add('open'); }
}
function closeDrawer() {
  document.getElementById('mob-drawer').classList.remove('open');
  document.getElementById('mob-backdrop').classList.remove('open');
}

// ── INIT ──────────────────────────────────────────────────────────────
toggleBedrag();
refreshAll();
</script>
