<!DOCTYPE html>
<html lang="nl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="theme-color" content="#060a12">
<title>Politie Systeem — Nationaal Database</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Syne:wght@700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#060a12;--s1:#0b1220;--s2:#0f1829;--s3:#131e30;
  --b1:rgba(255,255,255,.055);--b2:rgba(255,255,255,.10);--b3:rgba(255,255,255,.16);
  --blue:#1d4ed8;--blue2:#2563eb;--blue3:#3b82f6;--blue-d:rgba(37,99,235,.14);--blue-g:rgba(37,99,235,.28);
  --gold:#ca9a3c;--gold-d:rgba(202,154,60,.13);
  --red:#c0392b;--red2:#dc2626;--red-d:rgba(220,38,38,.13);
  --amber:#b45309;--amber-d:rgba(180,83,9,.13);
  --green:#15803d;--green-d:rgba(21,128,61,.13);
  --purple:#7c3aed;--purple-d:rgba(124,58,237,.13);
  --t1:#f0f4ff;--t2:#8ca0be;--t3:#3d5270;--t4:#243044;
  --r:10px;--r2:8px;--r3:6px;--hdr:60px;--sidebar:340px;
}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth;-webkit-text-size-adjust:100%}
body{background:var(--bg);color:var(--t2);font-family:'DM Sans',sans-serif;min-height:100vh;overflow-x:hidden;font-size:15px;line-height:1.5}
body::before{content:'';position:fixed;inset:0;z-index:0;pointer-events:none;background:radial-gradient(ellipse 900px 500px at 15% -5%,rgba(29,78,216,.07) 0%,transparent 65%),radial-gradient(ellipse 700px 400px at 85% 105%,rgba(29,78,216,.05) 0%,transparent 65%)}
img,svg{display:block}
button{font-family:inherit;cursor:pointer;border:none;background:none}
input,select,textarea{font-family:inherit;font-size:inherit}
::-webkit-scrollbar{width:4px;height:4px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:rgba(59,130,246,.35);border-radius:4px}

/* HEADER */
#header{position:fixed;top:0;left:0;right:0;z-index:100;height:var(--hdr);background:rgba(6,10,18,.92);backdrop-filter:blur(24px);-webkit-backdrop-filter:blur(24px);border-bottom:1px solid var(--b1);display:flex;align-items:center;justify-content:space-between;padding:0 1.5rem;gap:1rem}
.hdr-logo{display:flex;align-items:center;gap:10px;flex-shrink:0}
.hdr-badge{width:34px;height:34px;border-radius:var(--r3);background:var(--blue2);display:flex;align-items:center;justify-content:center;flex-shrink:0}
.hdr-title{font-family:'Syne',sans-serif;font-size:.95rem;font-weight:700;color:var(--t1);letter-spacing:.04em;line-height:1}
.hdr-sub{font-family:'DM Mono',monospace;font-size:.55rem;color:var(--t3);letter-spacing:.18em;text-transform:uppercase;margin-top:2px}
.hdr-right{display:flex;align-items:center;gap:1rem;flex-shrink:0}
.hdr-status{display:flex;align-items:center;gap:6px;font-family:'DM Mono',monospace;font-size:.6rem;color:var(--t3);letter-spacing:.1em;border:1px solid var(--b1);border-radius:100px;padding:3px 10px}
.status-dot{width:5px;height:5px;border-radius:50%;background:#22c55e;box-shadow:0 0 6px #22c55e;animation:blink 2.5s ease-in-out infinite}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.3}}
.hdr-clock{font-family:'DM Mono',monospace;font-size:.8rem;color:var(--t2);letter-spacing:.1em;min-width:68px;text-align:right}
.hdr-menu-btn{display:none;width:36px;height:36px;border-radius:var(--r3);border:1px solid var(--b2);color:var(--t2);align-items:center;justify-content:center}

/* LAYOUT */
#app{padding-top:var(--hdr);min-height:100vh;display:flex;flex-direction:column;position:relative;z-index:1}
.page{display:flex;flex:1;min-height:calc(100vh - var(--hdr))}

/* NAV TABS (Personen / Zaken) */
.nav-tabs{display:flex;gap:2px;padding:0 1rem;border-bottom:1px solid var(--b1);background:var(--s1);flex-shrink:0}
.nav-tab{font-family:'DM Mono',monospace;font-size:.62rem;letter-spacing:.12em;text-transform:uppercase;color:var(--t3);padding:10px 12px;border-bottom:2px solid transparent;cursor:pointer;transition:color .15s,border-color .15s;display:flex;align-items:center;gap:6px;white-space:nowrap}
.nav-tab:hover{color:var(--t2)}
.nav-tab.active{color:var(--blue3);border-bottom-color:var(--blue2)}
.nav-tab-badge{background:var(--blue-d);color:var(--blue3);border-radius:100px;padding:1px 6px;font-size:.55rem}

/* SIDEBAR */
#sidebar{width:var(--sidebar);flex-shrink:0;background:var(--s1);border-right:1px solid var(--b1);display:flex;flex-direction:column;position:sticky;top:var(--hdr);height:calc(100vh - var(--hdr));overflow:hidden}
.sb-search{padding:1rem;border-bottom:1px solid var(--b1)}
.sb-search-label{font-family:'DM Mono',monospace;font-size:.58rem;color:var(--t3);letter-spacing:.2em;text-transform:uppercase;margin-bottom:6px}
.sb-search-row{display:flex;gap:6px}
.sb-search-box{position:relative;flex:1}
.sb-search-ico{position:absolute;left:10px;top:50%;transform:translateY(-50%);color:var(--t3);pointer-events:none;transition:color .2s}
.sb-search-box:focus-within .sb-search-ico{color:var(--blue3)}
.sb-input{width:100%;background:var(--s2);border:1px solid var(--b1);border-radius:var(--r2);color:var(--t1);font-size:.875rem;padding:0 .75rem 0 2.25rem;height:38px;outline:none;transition:border-color .2s,box-shadow .2s}
.sb-input::placeholder{color:var(--t3)}
.sb-input:focus{border-color:var(--blue2);box-shadow:0 0 0 3px var(--blue-d)}
.sb-add-btn{height:38px;padding:0 .75rem;background:var(--blue2);border-radius:var(--r2);color:#fff;font-size:.8rem;font-weight:500;display:flex;align-items:center;gap:5px;flex-shrink:0;transition:background .15s,box-shadow .15s;white-space:nowrap}
.sb-add-btn:hover{background:var(--blue3);box-shadow:0 3px 12px var(--blue-g)}
.sb-search-mode{display:flex;gap:4px;margin-top:8px}
.sb-mode-btn{flex:1;height:26px;font-family:'DM Mono',monospace;font-size:.56rem;letter-spacing:.08em;text-transform:uppercase;border-radius:5px;border:1px solid var(--b1);color:var(--t3);background:transparent;cursor:pointer;transition:background .15s,color .15s,border-color .15s}
.sb-mode-btn.active{background:var(--blue-d);color:var(--blue3);border-color:rgba(37,99,235,.3)}
.sb-results{flex:1;overflow-y:auto;padding:8px}
.sb-count{font-family:'DM Mono',monospace;font-size:.58rem;color:var(--t3);letter-spacing:.1em;padding:6px 4px 4px;text-transform:uppercase}
.sb-nf{margin:4px;padding:10px 12px;background:rgba(37,99,235,.06);border:1px solid rgba(37,99,235,.18);border-radius:var(--r2);display:none}
.sb-nf.show{display:block}
.sb-nf p{font-family:'DM Mono',monospace;font-size:.62rem;color:var(--t2);letter-spacing:.04em;line-height:1.7}
.sb-nf-btn{margin-top:8px;width:100%}
.sb-empty{padding:2.5rem 1rem;text-align:center}
.sb-empty-icon{width:38px;height:38px;border-radius:var(--r2);background:rgba(255,255,255,.03);border:1px solid var(--b1);display:flex;align-items:center;justify-content:center;margin:0 auto 10px}
.sb-empty p{font-family:'DM Mono',monospace;font-size:.62rem;color:var(--t3);letter-spacing:.1em;line-height:2;text-transform:uppercase}

/* PERSON ROW */
.person-row{display:flex;align-items:center;gap:10px;padding:9px 10px;border-radius:var(--r2);border:1px solid transparent;cursor:pointer;transition:background .15s,border-color .15s;animation:rowIn .18s ease both}
@keyframes rowIn{from{opacity:0;transform:translateX(-5px)}to{opacity:1;transform:translateX(0)}}
.person-row:hover{background:rgba(255,255,255,.03);border-color:var(--b1)}
.person-row.active{background:var(--blue-d);border-color:rgba(37,99,235,.3)}
.pr-av{width:36px;height:36px;border-radius:var(--r3);flex-shrink:0;background:linear-gradient(135deg,var(--blue2) 0%,#1e3a8a 100%);display:flex;align-items:center;justify-content:center;font-family:'Syne',sans-serif;font-size:.72rem;font-weight:700;color:#fff;letter-spacing:.05em}
.pr-info{flex:1;min-width:0}
.pr-name{font-size:.875rem;font-weight:500;color:var(--t1);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.pr-meta{font-family:'DM Mono',monospace;font-size:.58rem;color:var(--t3);letter-spacing:.04em;margin-top:1px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.pr-chips{display:flex;gap:3px;flex-wrap:wrap;flex-shrink:0}

/* ZAAK ROW */
.zaak-row{display:flex;align-items:flex-start;gap:10px;padding:9px 10px;border-radius:var(--r2);border:1px solid transparent;cursor:pointer;transition:background .15s,border-color .15s;animation:rowIn .18s ease both}
.zaak-row:hover{background:rgba(255,255,255,.03);border-color:var(--b1)}
.zaak-row.active{background:var(--blue-d);border-color:rgba(37,99,235,.3)}
.zaak-icon{width:36px;height:36px;border-radius:var(--r3);flex-shrink:0;background:linear-gradient(135deg,var(--purple) 0%,#4c1d95 100%);display:flex;align-items:center;justify-content:center;color:#fff}
.zaak-info{flex:1;min-width:0}
.zaak-title{font-size:.875rem;font-weight:500;color:var(--t1);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.zaak-meta{font-family:'DM Mono',monospace;font-size:.58rem;color:var(--t3);letter-spacing:.04em;margin-top:1px}

/* MAIN */
#main{flex:1;overflow-y:auto;display:flex;flex-direction:column}
.main-empty{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:12px;padding:3rem;text-align:center}
.main-empty-icon{width:52px;height:52px;border-radius:var(--r);background:rgba(255,255,255,.03);border:1px solid var(--b1);display:flex;align-items:center;justify-content:center;margin:0 auto}
.main-empty h2{font-family:'Syne',sans-serif;font-size:1rem;font-weight:700;color:var(--t2);letter-spacing:.04em}
.main-empty p{font-family:'DM Mono',monospace;font-size:.62rem;color:var(--t3);letter-spacing:.08em;line-height:2;text-transform:uppercase}

/* DOSSIER */
.dossier{padding:1.5rem;max-width:900px;width:100%;animation:fadeUp .25s ease both}
@keyframes fadeUp{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}
.dos-topbar{display:flex;align-items:flex-start;justify-content:space-between;gap:1rem;margin-bottom:1.25rem;flex-wrap:wrap}
.dos-name-row{display:flex;align-items:center;gap:8px}
.dos-name{font-family:'Syne',sans-serif;font-size:1.75rem;font-weight:800;color:var(--t1);letter-spacing:-.01em;line-height:1}
.icon-btn{width:28px;height:28px;border-radius:var(--r3);border:1px solid var(--b1);color:var(--t3);display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:background .15s,color .15s,border-color .15s}
.icon-btn:hover{background:var(--blue-d);color:var(--blue3);border-color:rgba(37,99,235,.3)}
.dos-id{font-family:'DM Mono',monospace;font-size:.6rem;color:var(--t3);letter-spacing:.15em;margin-top:3px}
.dos-chips{display:flex;gap:5px;flex-wrap:wrap;margin-top:8px}
.dos-actions{display:flex;gap:6px;flex-wrap:wrap}

/* STATUS CHIP (persoon status) */
.status-vrij{background:rgba(21,128,61,.15);color:#4ade80;border:1px solid rgba(21,128,61,.3)}
.status-opgepakt{background:rgba(220,38,38,.15);color:#f87171;border:1px solid rgba(220,38,38,.3)}
.status-voortvluchtig{background:rgba(180,83,9,.15);color:#fb923c;border:1px solid rgba(180,83,9,.3)}

/* INFO GRID */
.info-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:1.25rem}
.info-block{background:var(--s2);border:1px solid var(--b1);border-radius:var(--r2);padding:10px 12px}
.info-label{font-family:'DM Mono',monospace;font-size:.56rem;color:var(--t3);letter-spacing:.18em;text-transform:uppercase;margin-bottom:3px}
.info-val{font-size:.9rem;font-weight:500;color:var(--t1)}
.info-val.grn{color:#4ade80}
.info-val.red{color:#f87171}
.info-val.mut{color:var(--t3)}
.info-val.gld{color:#f0b429}
.plaat-row{display:flex;align-items:center;gap:6px}
.plaat-tag{font-family:'DM Mono',monospace;font-size:.8rem;font-weight:500;color:var(--t1);background:var(--s3);border:1px solid var(--b2);border-radius:4px;padding:1px 8px;letter-spacing:.1em}
.plaat-none{font-size:.85rem;color:var(--t3)}

/* SECTION */
.section{margin-bottom:1.25rem}
.section-hdr{display:flex;align-items:center;gap:8px;margin-bottom:8px}
.section-title{font-family:'DM Mono',monospace;font-size:.6rem;color:var(--t3);letter-spacing:.2em;text-transform:uppercase}
.section-title::after{content:'';display:inline-block;width:60px;height:1px;background:var(--b1);vertical-align:middle;margin-left:8px}
.rec-row{display:flex;align-items:center;gap:10px;padding:10px 12px;background:var(--s2);border:1px solid var(--b1);border-radius:var(--r2);margin-bottom:5px;transition:border-color .15s;position:relative}
.rec-row:hover{border-color:var(--b2)}
.rec-dot{width:3px;align-self:stretch;border-radius:3px;flex-shrink:0}
.d-gold{background:#ca9a3c;box-shadow:0 0 5px rgba(202,154,60,.4)}
.d-red{background:#dc2626;box-shadow:0 0 5px rgba(220,38,38,.4)}
.d-blue{background:#3b82f6;box-shadow:0 0 5px rgba(59,130,246,.4)}
.d-purple{background:#7c3aed;box-shadow:0 0 5px rgba(124,58,237,.4)}
.rec-body{flex:1;min-width:0}
.rec-reden{font-size:.875rem;color:var(--t1);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.rec-datum{font-family:'DM Mono',monospace;font-size:.58rem;color:var(--t3);margin-top:1px}
.rec-bedrag{font-family:'DM Mono',monospace;font-size:.8rem;color:#f0b429;flex-shrink:0;margin-right:34px}
.rec-del{position:absolute;right:8px;top:50%;transform:translateY(-50%);width:24px;height:24px;border-radius:5px;border:1px solid transparent;color:var(--t3);display:flex;align-items:center;justify-content:center;opacity:0;transition:opacity .15s,background .15s,color .15s,border-color .15s}
.rec-row:hover .rec-del{opacity:1}
.rec-del:hover{background:var(--red-d);color:#f87171;border-color:rgba(220,38,38,.25)}
.no-rec{font-family:'DM Mono',monospace;font-size:.62rem;color:var(--t3);padding:8px 0;letter-spacing:.08em}

/* ZAKEN CARDS */
.zaak-card{background:var(--s2);border:1px solid var(--b1);border-radius:var(--r2);padding:12px 14px;margin-bottom:8px;cursor:pointer;transition:border-color .15s}
.zaak-card:hover{border-color:var(--blue2)}
.zaak-card-top{display:flex;align-items:flex-start;justify-content:space-between;gap:8px;margin-bottom:6px}
.zaak-card-num{font-family:'DM Mono',monospace;font-size:.6rem;color:var(--t3);letter-spacing:.12em}
.zaak-card-title{font-size:.9rem;font-weight:500;color:var(--t1);margin-top:2px}
.zaak-card-betrokkenen{display:flex;gap:4px;flex-wrap:wrap;margin-top:6px}
.zaak-betrokkene-tag{font-family:'DM Mono',monospace;font-size:.6rem;color:var(--t2);background:rgba(255,255,255,.04);border:1px solid var(--b1);border-radius:4px;padding:1px 6px;cursor:pointer;transition:background .15s,color .15s}
.zaak-betrokkene-tag:hover{background:var(--blue-d);color:var(--blue3)}

/* CHIPS */
.chip{display:inline-flex;align-items:center;gap:4px;font-family:'DM Mono',monospace;font-size:.58rem;font-weight:500;padding:2px 7px;border-radius:100px;letter-spacing:.04em;white-space:nowrap}
.c-blue{background:var(--blue-d);color:#60a5fa;border:1px solid rgba(37,99,235,.22)}
.c-red{background:var(--red-d);color:#f87171;border:1px solid rgba(220,38,38,.22)}
.c-amber{background:var(--amber-d);color:#fbbf24;border:1px solid rgba(180,83,9,.22)}
.c-gold{background:var(--gold-d);color:#f0b429;border:1px solid rgba(202,154,60,.22)}
.c-green{background:var(--green-d);color:#4ade80;border:1px solid rgba(21,128,61,.22)}
.c-purple{background:var(--purple-d);color:#a78bfa;border:1px solid rgba(124,58,237,.22)}
.c-muted{background:rgba(61,82,112,.18);color:var(--t3);border:1px solid rgba(61,82,112,.25)}

/* BUTTONS */
.btn{display:inline-flex;align-items:center;gap:6px;font-family:'DM Sans',sans-serif;font-size:.82rem;font-weight:500;height:34px;padding:0 12px;border-radius:var(--r2);border:none;cursor:pointer;transition:background .15s,box-shadow .15s,transform .1s;white-space:nowrap;letter-spacing:.01em}
.btn:active{transform:scale(.97)}
.btn-primary{background:var(--blue2);color:#fff}
.btn-primary:hover{background:var(--blue3);box-shadow:0 4px 14px var(--blue-g)}
.btn-ghost{background:rgba(255,255,255,.04);color:var(--t2);border:1px solid var(--b1)}
.btn-ghost:hover{background:rgba(255,255,255,.07);border-color:var(--b2)}
.btn-danger{background:var(--red-d);color:#f87171;border:1px solid rgba(220,38,38,.22)}
.btn-danger:hover{background:rgba(220,38,38,.22)}
.btn-amber{background:var(--amber-d);color:#fbbf24;border:1px solid rgba(180,83,9,.22)}
.btn-amber:hover{background:rgba(180,83,9,.22)}
.btn-purple{background:var(--purple-d);color:#a78bfa;border:1px solid rgba(124,58,237,.22)}
.btn-purple:hover{background:rgba(124,58,237,.22)}
.btn-full{width:100%;justify-content:center}
.btn-sm{height:30px;font-size:.78rem;padding:0 10px}

/* RIGHT PANEL */
#right-panel{width:280px;flex-shrink:0;border-left:1px solid var(--b1);background:var(--s1);position:sticky;top:var(--hdr);height:calc(100vh - var(--hdr));overflow-y:auto;display:flex;flex-direction:column}
.rp-section{border-bottom:1px solid var(--b1);padding:1rem}
.rp-title{font-family:'DM Mono',monospace;font-size:.58rem;color:var(--t3);letter-spacing:.2em;text-transform:uppercase;margin-bottom:10px;display:flex;align-items:center;gap:6px}
.stat-row{display:flex;align-items:center;justify-content:space-between;padding:7px 0;border-bottom:1px solid var(--b1)}
.stat-row:last-child{border-bottom:none}
.stat-name{font-size:.84rem;color:var(--t2)}
.stat-val{font-family:'DM Mono',monospace;font-size:.88rem;font-weight:500}
.sv-blue{color:var(--blue3)}.sv-gold{color:#f0b429}.sv-red{color:#f87171}.sv-amber{color:#fbbf24}.sv-purple{color:#a78bfa}
.recent-row{display:flex;align-items:center;justify-content:space-between;padding:7px 0;border-bottom:1px solid var(--b1);cursor:pointer;transition:background .15s;border-radius:4px}
.recent-row:last-child{border-bottom:none}
.recent-row:hover{background:rgba(255,255,255,.02)}
.recent-name{font-size:.84rem;color:var(--t1)}
.recent-date{font-family:'DM Mono',monospace;font-size:.58rem;color:var(--t3)}
.rp-qa{display:flex;flex-direction:column;gap:5px}

/* FOOTER */
footer{border-top:1px solid var(--b1);padding:.75rem 1.5rem;display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap;background:var(--s1)}
.footer-credits{font-family:'DM Mono',monospace;font-size:.58rem;color:var(--t3);letter-spacing:.1em}
.footer-credits strong{color:var(--t2);font-weight:500}
.footer-ver{font-family:'DM Mono',monospace;font-size:.56rem;color:var(--t4);letter-spacing:.1em}

/* OVERLAY / MODALS */
.overlay{display:none;position:fixed;inset:0;z-index:500;background:rgba(3,6,14,.88);backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px);align-items:center;justify-content:center;padding:1rem}
.overlay.open{display:flex}
.modal{background:var(--s2);border:1px solid var(--b2);border-radius:var(--r);width:100%;max-width:460px;max-height:90vh;overflow-y:auto;box-shadow:0 24px 80px rgba(0,0,0,.7),0 0 0 1px rgba(255,255,255,.04);animation:mIn .2s cubic-bezier(.22,.68,0,1.15) both}
.modal-lg{max-width:560px}
@keyframes mIn{from{opacity:0;transform:scale(.95) translateY(10px)}to{opacity:1;transform:scale(1) translateY(0)}}
.modal-sm{max-width:340px}
.mhd{padding:14px 18px;border-bottom:1px solid var(--b1);display:flex;align-items:center;justify-content:space-between}
.mhd-title{font-family:'Syne',sans-serif;font-size:.88rem;font-weight:700;color:var(--t1);letter-spacing:.02em}
.m-close{width:26px;height:26px;background:rgba(255,255,255,.04);border:1px solid var(--b1);border-radius:5px;color:var(--t3);display:flex;align-items:center;justify-content:center;transition:background .15s,color .15s}
.m-close:hover{background:var(--red-d);color:#f87171}
.mbody{padding:16px 18px;display:flex;flex-direction:column;gap:11px}
.mfoot{padding:11px 18px;border-top:1px solid var(--b1);display:flex;justify-content:flex-end;gap:7px;background:rgba(0,0,0,.15)}
.form-group{display:flex;flex-direction:column;gap:4px}
.form-row2{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.form-label{font-family:'DM Mono',monospace;font-size:.58rem;color:var(--t3);letter-spacing:.18em;text-transform:uppercase}
.form-input,.form-select,.form-textarea{background:var(--s1);border:1px solid var(--b1);border-radius:var(--r2);color:var(--t1);font-size:.875rem;padding:0 11px;height:38px;outline:none;width:100%;transition:border-color .2s,box-shadow .2s;-webkit-appearance:none}
.form-input::placeholder{color:var(--t3)}
.form-select option{background:var(--s2)}
.form-input:focus,.form-select:focus,.form-textarea:focus{border-color:var(--blue2);box-shadow:0 0 0 3px var(--blue-d)}
.form-textarea{height:auto;min-height:72px;padding:9px 11px;resize:vertical}
.form-warn{font-family:'DM Mono',monospace;font-size:.58rem;color:#f87171;display:none}
.confirm-text{font-size:.875rem;color:var(--t2);line-height:1.7}

/* betrokkenen multi-select in modal */
.betrokkenen-list{display:flex;flex-direction:column;gap:4px;max-height:180px;overflow-y:auto;background:var(--s1);border:1px solid var(--b1);border-radius:var(--r2);padding:6px}
.betrokkene-opt{display:flex;align-items:center;gap:8px;padding:6px 8px;border-radius:6px;cursor:pointer;transition:background .12s}
.betrokkene-opt:hover{background:rgba(255,255,255,.04)}
.betrokkene-opt input[type=checkbox]{width:14px;height:14px;accent-color:var(--blue2);cursor:pointer;flex-shrink:0}
.betrokkene-opt label{font-size:.875rem;color:var(--t1);cursor:pointer;flex:1}

/* MOBILE DRAWER */
#mob-drawer{display:none;position:fixed;top:var(--hdr);bottom:0;left:0;z-index:90;width:min(320px,90vw);background:var(--s1);border-right:1px solid var(--b1);flex-direction:column;overflow:hidden;transform:translateX(-100%);transition:transform .25s ease}
#mob-drawer.open{transform:translateX(0)}
#mob-backdrop{display:none;position:fixed;inset:0;z-index:89;background:rgba(0,0,0,.5);top:var(--hdr)}
#mob-backdrop.open{display:block}

/* RESPONSIVE */
@media(max-width:1100px){#right-panel{display:none}}
@media(max-width:760px){
  :root{--sidebar:0px}
  #sidebar{display:none}
  #mob-drawer{display:flex}
  .hdr-menu-btn{display:flex}
  .hdr-status{display:none}
  .dossier{padding:1rem}
  .info-grid{grid-template-columns:1fr 1fr}
  .dos-name{font-size:1.4rem}
  footer{flex-direction:column;align-items:flex-start;gap:.5rem}
}
@media(max-width:480px){
  .info-grid{grid-template-columns:1fr}
  .dos-actions{gap:5px}
  .btn{font-size:.78rem;padding:0 10px}
  .form-row2{grid-template-columns:1fr}
}
</style>
</head>
