function openEditStatus(id) {
  activePid=id; var p=findP(id);
  document.getElementById('sStatus').value=p.status||'vrij';
  document.getElementById('mStatus').classList.add('open');
}
function doStatus() {
  var p=findP(activePid); if(!p) return;
  p.status=document.getElementById('sStatus').value;
  saveDB(); closeM('mStatus'); refreshAll();
  if(activeId===activePid) showDossier(buildDossier(p));
}
function openEditPlaat(id) {
  activePid=id; var p=findP(id);
  document.getElementById('pPlaat').value=p.nummerplaat||'';
  document.getElementById('mPlaatTitle').textContent='Nummerplaat — '+p.naam;
  document.getElementById('mPlaat').classList.add('open');
