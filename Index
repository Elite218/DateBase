// ── STATUS HELPERS ────────────────────────────────────────────────────
function statusChip(p) {
  var s = p.status || 'vrij';
  if(s==='opgepakt')     return '<span class="chip status-opgepakt">'     + I.lock + ' Opgepakt</span>';
  if(s==='voortvluchtig') return '<span class="chip status-voortvluchtig">' + I.run  + ' Voortvluchtig</span>';
  return '<span class="chip status-vrij">Vrij</span>';
}

function zaakStatusChip(z) {
  if(z.status==='gesloten') return '<span class="chip c-muted">Gesloten</span>';
  if(z.status==='lopend')   return '<span class="chip c-blue">Lopend onderzoek</span>';
  return '<span class="chip c-amber">Open</span>';
}

function zaakTypeChip(z) {
  var map = {misdrijf:'c-red',overtreding:'c-gold',vermissing:'c-purple',onderzoek:'c-blue',incident:'c-amber'};
  var cls = map[z.type] || 'c-muted';
  return '<span class="chip ' + cls + '">' + esc(z.type||'') + '</span>';
}

// ── PERSON CHIPS ──────────────────────────────────────────────────────
function chips(p) {
  var rec = p.records||[];
  var bo = rec.filter(function(r){ return r.type==='boete'; }).length;
  var ar = rec.filter(function(r){ return r.type==='arrest'; }).length;
  var wa = rec.filter(function(r){ return r.type==='waarschuwing'; }).length;
  var out = '';
  if(ar) out += '<span class="chip c-red">'   + I.arrest + ' ' + ar + '</span>';
  if(bo) out += '<span class="chip c-gold">'  + I.boete  + ' ' + bo + '</span>';
  if(wa) out += '<span class="chip c-amber">' + I.warn   + ' ' + wa + '</span>';
  if(p.rijbewijs==='ingetrokken') out += '<span class="chip c-red">' + I.rij + '</span>';
  var s = p.status||'vrij';
  if(s==='opgepakt') out += '<span class="chip status-opgepakt">' + I.lock + '</span>';
  if(s==='voortvluchtig') out += '<span class="chip status-voortvluchtig">' + I.run + '</span>';
  return out || '<span class="chip c-muted">Schoon</span>';
}

// ── TAB SWITCHING ─────────────────────────────────────────────────────
function toonTab(tab) {
  activeTab = tab;
  lastQuery = '';
  renderSidebar('');
  closeDrawer();
}

// ── SIDEBAR ───────────────────────────────────────────────────────────
function renderSidebar(query) {
  if(query === undefined) query = lastQuery;
  lastQuery = query;
  var html = buildSidebar(query);
  var sb = document.getElementById('sb-inner');
  var mob = document.getElementById('mob-inner');
  if(sb) sb.innerHTML = html;
  if(mob) mob.innerHTML = html;
}

function buildSidebar(query) {
  var q = (query||'').trim();
  var h = '';

  // Tab bar
  var pCount = db.length;
  var zCount = zdb.length;
  h += '<div class="nav-tabs">';
  h += '<div class="nav-tab' + (activeTab==='personen'?' active':'') + '" onclick="toonTab(\'personen\')">';
  h += '<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>';
  h += 'Personen <span class="nav-tab-badge">' + pCount + '</span></div>';
  h += '<div class="nav-tab' + (activeTab==='zaken'?' active':'') + '" onclick="toonTab(\'zaken\')">';
  h += '<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/></svg>';
  h += 'Zaken <span class="nav-tab-badge">' + zCount + '</span></div>';
  h += '</div>';

  if(activeTab === 'personen') {
    h += buildPersonenSidebar(q);
  } else {
    h += buildZakenSidebar(q);
  }
  return h;
}

function buildPersonenSidebar(q) {
  var h = '';
  h += '<div class="sb-search">';
  h += '<div class="sb-search-label">Burger opzoeken</div>';
  h += '<div class="sb-search-row">';
  h += '<div class="sb-search-box"><span class="sb-search-ico">' + I.search + '</span>';
  h += '<input type="text" class="sb-input" id="sbInput" placeholder="' + (searchMode==='plaat'?'Nummerplaat...':'Naam invoeren...') + '" value="' + esc(q) + '" oninput="onSearch(this.value)">';
  h += '</div>';
  h += '<button class="sb-add-btn btn" onclick="openM(\'mAdd\')">' + I.plus + 'Nieuw</button>';
  h += '</div>';
  h += '<div class="sb-search-mode">';
  h += '<button class="sb-mode-btn' + (searchMode==='naam'?' active':'') + '" onclick="setSearchMode(\'naam\')">Op naam</button>';
  h += '<button class="sb-mode-btn' + (searchMode==='plaat'?' active':'') + '" onclick="setSearchMode(\'plaat\')">Op nummerplaat</button>';
  h += '</div></div>';

  h += '<div class="sb-results">';

  if(!q) {
    if(!db.length) {
      h += '<div class="sb-empty"><div class="sb-empty-icon">' + I.search + '</div><p>Database leeg</p></div>';
    } else {
      h += '<div class="sb-count">' + db.length + ' personen totaal</div>';
      db.forEach(function(p, i) {
        h += personRow(p, i);
      });
    }
  } else {
    var results;
    if(searchMode === 'plaat') {
      var ql = q.toLowerCase().replace(/[-\s]/g,'');
      results = db.filter(function(p){ return p.nummerplaat && p.nummerplaat.toLowerCase().replace(/[-\s]/g,'').indexOf(ql) !== -1; });
    } else {
      var ql2 = q.toLowerCase();
      results = db.filter(function(p){ return p.naam.toLowerCase().indexOf(ql2) !== -1; });
    }

    if(!results.length) {
      h += '<div class="sb-count">0 resultaten</div>';
      h += '<div class="sb-empty"><div class="sb-empty-icon">' + I.del + '</div><p>Niet gevonden</p></div>';
      h += '</div>';
      h += '<div class="sb-nf show"><p>' + (searchMode==='plaat'?'Nummerplaat niet gevonden.':'Persoon niet gevonden.') + '</p>';
      if(searchMode==='naam') h += '<button class="btn btn-primary btn-sm btn-full sb-nf-btn" onclick="openAddWithName()">' + I.plus + ' Toevoegen</button>';
      h += '</div>';
      return h;
    }

    h += '<div class="sb-count">' + results.length + ' resultaat' + (results.length!==1?'en':'') + '</div>';
    results.forEach(function(p, i) { h += personRow(p, i); });
  }

  h += '</div>';
  return h;
}

function personRow(p, i) {
  var act = p.id === activeId ? ' active' : '';
  var h = '<div class="person-row' + act + '" onclick="selectPerson(\'' + p.id + '\')" style="animation-delay:' + (i*0.04) + 's">';
  h += '<div class="pr-av">' + initials(p.naam) + '</div>';
  h += '<div class="pr-info">';
  h += '<div class="pr-name">' + esc(p.naam) + '</div>';
  h += '<div class="pr-meta">' + fDate(p.aangemaakt) + (p.nummerplaat?' &middot; '+esc(p.nummerplaat):'') + '</div>';
  h += '</div>';
  h += '<div class="pr-chips">' + chips(p) + '</div>';
  h += '</div>';
  return h;
}

function buildZakenSidebar(q) {
  var h = '';
  h += '<div class="sb-search">';
  h += '<div class="sb-search-label">Zaak opzoeken</div>';
  h += '<div class="sb-search-row">';
  h += '<div class="sb-search-box"><span class="sb-search-ico">' + I.search + '</span>';
  h += '<input type="text" class="sb-input" id="sbInput" placeholder="Zaaktitel..." value="' + esc(q) + '" oninput="onSearch(this.value)">';
  h += '</div>';
  h += '<button class="sb-add-btn btn" onclick="openM(\'mZaak\')">' + I.plus + 'Nieuw</button>';
  h += '</div></div>';

  h += '<div class="sb-results">';
  var list = q ? zdb.filter(function(z){ return z.titel.toLowerCase().indexOf(q.toLowerCase())!==-1; }) : zdb;

  if(!list.length) {
    h += '<div class="sb-empty"><div class="sb-empty-icon">' + I.zaak + '</div><p>' + (q?'Niet gevonden':'Geen zaken<br>aangemaakt') + '</p></div>';
  } else {
    h += '<div class="sb-count">' + list.length + ' zaak' + (list.length!==1?'en':'') + '</div>';
    list.forEach(function(z, i) {
      var act = z.id===activeZaakId?' active':'';
      h += '<div class="zaak-row' + act + '" onclick="selectZaak(\'' + z.id + '\')" style="animation-delay:' + (i*0.04) + 's">';
      h += '<div class="zaak-icon">' + I.zaak + '</div>';
      h += '<div class="zaak-info">';
      h += '<div class="zaak-title">' + esc(z.titel) + '</div>';
      h += '<div class="zaak-meta">' + fDate(z.aangemaakt) + ' &middot; ' + (z.betrokkenen||[]).length + ' betrokkene(n)</div>';
      h += '</div>';
      h += zaakStatusChip(z);
      h += '</div>';
    });
  }
  h += '</div>';
  return h;
}

function setSearchMode(mode) {
  searchMode = mode;
  renderSidebar('');
  setTimeout(function(){ var i=document.getElementById('sbInput'); if(i)i.focus(); }, 50);
}

function onSearch(val) { renderSidebar(val); }

function openAddWithName() {
  var inp = document.getElementById('sbInput');
  var val = inp ? inp.value.trim() : '';
  document.getElementById('aNaam').value = val;
  openM('mAdd');
}

// ── STATS & RECENT ────────────────────────────────────────────────────
function renderStats() {
  var bo=0,ar=0,wa=0,ri=0,opgepakt=0,voortvluchtig=0;
  db.forEach(function(p) {
    (p.records||[]).forEach(function(r) {
      if(r.type==='boete') bo++;
      if(r.type==='arrest') ar++;
      if(r.type==='waarschuwing') wa++;
    });
    if(p.rijbewijs==='ingetrokken') ri++;
    if(p.status==='opgepakt') opgepakt++;
    if(p.status==='voortvluchtig') voortvluchtig++;
  });
  function sr(lbl,val,cls) { return '<div class="stat-row"><span class="stat-name">'+lbl+'</span><span class="stat-val '+cls+'">'+val+'</span></div>'; }
  var h = '';
  h += sr('Personen', db.length, 'sv-blue');
  h += sr('Boetes', bo, 'sv-gold');
  h += sr('Arrestaties', ar, 'sv-red');
  h += sr('Waarschuwingen', wa, 'sv-amber');
  h += sr('Rijbewijs ingetrokken', ri, 'sv-red');
  h += sr('Opgepakt', opgepakt, 'sv-red');
  h += sr('Voortvluchtig', voortvluchtig, 'sv-amber');
  h += sr('Open zaken', zdb.filter(function(z){ return z.status!=='gesloten'; }).length, 'sv-purple');
  var el = document.getElementById('statsBlock'); if(el) el.innerHTML = h;
}

function renderRecent() {
  var el = document.getElementById('recentBlock'); if(!el) return;
  var r = db.slice().sort(function(a,b){ return new Date(b.aangemaakt)-new Date(a.aangemaakt); }).slice(0,5);
  if(!r.length) { el.innerHTML='<div style="font-family:DM Mono,monospace;font-size:.62rem;color:var(--t3);padding:4px 0">Geen personen</div>'; return; }
  el.innerHTML = r.map(function(p) {
    return '<div class="recent-row" onclick="selectPerson(\''+p.id+'\')">'
      +'<span class="recent-name">'+esc(p.naam)+'</span>'
      +'<span class="recent-date">'+fDate(p.aangemaakt)+'</span></div>';
  }).join('');
}

function refreshAll() {
  renderSidebar();
  renderStats();
  renderRecent();
}

// ── SELECT PERSOON ────────────────────────────────────────────────────
function selectPerson(id) {
  activeId = id;
  activeZaakId = null;
  var p = findP(id); if(!p) return;
  renderSidebar();
  closeDrawer();
  showDossier(buildDossier(p));
}

function buildDossier(p) {
  var rec = p.records||[];
  var bo = rec.filter(function(r){ return r.type==='boete'; });
  var ar = rec.filter(function(r){ return r.type==='arrest'; });
  var wa = rec.filter(function(r){ return r.type==='waarschuwing'; });
  var no = rec.filter(function(r){ return r.type==='notitie'; });
  var totaal = bo.reduce(function(s,r){ return s+(parseFloat(r.bedrag)||0); }, 0);

  var dosStatus, dosCls;
  if(ar.length)           { dosStatus='Bekende crimineel'; dosCls='c-red'; }
  else if(bo.length||wa.length) { dosStatus='Bekende overtreder'; dosCls='c-amber'; }
  else                         { dosStatus='Schoon dossier';    dosCls='c-green'; }

  var rKls = p.rijbewijs==='geldig'?'grn':p.rijbewijs==='ingetrokken'?'red':'mut';
  var rTxt = p.rijbewijs==='geldig'?'Geldig':p.rijbewijs==='ingetrokken'?'Ingetrokken':'Geen';

  var plaatHtml = p.nummerplaat
    ? '<span class="plaat-tag">'+esc(p.nummerplaat)+'</span>'
    : '<span class="plaat-none">Niet ingesteld</span>';

  // Gekoppelde zaken
  var gekoppeldeZaken = zdb.filter(function(z){ return (z.betrokkenen||[]).indexOf(p.id)!==-1; });

  var h = '<div class="dos-topbar">';
  h += '<div>';
  h += '<div class="dos-name-row"><div class="dos-name">'+esc(p.naam)+'</div>';
  h += '<button class="icon-btn" onclick="openEditNaam(\''+p.id+'\')" title="Naam bewerken">'+I.edit+'</button></div>';
  h += '<div class="dos-id">ID: '+p.id+' &nbsp;&middot;&nbsp; Geregistreerd: '+fDate(p.aangemaakt)+'</div>';
  h += '<div class="dos-chips">'+statusChip(p)+'<span class="chip '+dosCls+'">'+dosStatus+'</span>'+chips(p)+'</div>';
  h += '</div>';
  h += '<div class="dos-actions">';
  h += '<button class="btn btn-primary btn-sm" onclick="openRecModal(\''+p.id+'\')">'+I.plus+' Record</button>';
  h += '<button class="btn btn-amber btn-sm" onclick="openEditRij(\''+p.id+'\')">'+I.rij+' Rijbewijs</button>';
  h += '<button class="btn btn-ghost btn-sm" onclick="openEditStatus(\''+p.id+'\')"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg> Status</button>';
  h += '<button class="btn btn-danger btn-sm" onclick="doVerwijder(\''+p.id+'\')">'+I.del+' Verwijder</button>';
  h += '</div></div>';

  h += '<div class="info-grid">';
  h += ib('Geboortedatum', fDate(p.geboortedatum));
  h += ib('Nationaliteit', esc(p.nationaliteit||'—'));
  h += ib('Rijbewijs', '<span class="'+rKls+'">'+rTxt+'</span>');
  h += ib('Totaal boetes', '<span class="gld">\u20AC'+totaal.toFixed(2)+'</span>');
  h += '<div class="info-block" style="grid-column:span 2"><div class="info-label">Nummerplaat</div>';
  h += '<div class="plaat-row">'+plaatHtml;
  h += '<button class="icon-btn" style="width:22px;height:22px" onclick="openEditPlaat(\''+p.id+'\')" title="Wijzigen">'+I.edit+'</button></div></div>';
  h += '</div>';

  h += recSec('Boetes', bo, 'd-gold', p);
  h += recSec('Arrestaties', ar, 'd-red', p);
  h += recSec('Waarschuwingen', wa, 'd-blue', p);
  if(no.length) h += recSec('Notities', no, 'd-gold', p);

  // Gekoppelde zaken sectie
  h += '<div class="section"><div class="section-hdr"><span class="section-title">Gekoppelde zaken ('+gekoppeldeZaken.length+')</span></div>';
  if(!gekoppeldeZaken.length) {
    h += '<div class="no-rec">Geen zaken gekoppeld aan deze persoon</div>';
  } else {
    gekoppeldeZaken.forEach(function(z) {
      h += '<div class="zaak-card" onclick="selectZaak(\''+z.id+'\')"><div class="zaak-card-top">';
      h += '<div><div class="zaak-card-num">'+z.id+'</div><div class="zaak-card-title">'+esc(z.titel)+'</div></div>';
      h += '<div style="display:flex;gap:4px;flex-shrink:0">'+zaakTypeChip(z)+zaakStatusChip(z)+'</div></div>';
      if(z.omschrijving) h += '<div style="font-size:.82rem;color:var(--t2);margin-top:4px;">'+esc(z.omschrijving)+'</div>';
      h += '</div>';
    });
  }
  h += '</div>';

  return h;
}

function ib(label, valHtml) {
  return '<div class="info-block"><div class="info-label">'+label+'</div><div class="info-val">'+valHtml+'</div></div>';
}

function recSec(title, lijst, dotCls, p) {
  var h = '<div class="section"><div class="section-hdr"><span class="section-title">'+title+' ('+lijst.length+')</span></div>';
  if(!lijst.length) { h += '<div class="no-rec">Geen geregistreerd</div>'; }
  else {
    lijst.forEach(function(r) {
      var idx = (p.records||[]).indexOf(r);
      var bedrag = r.type==='boete'?'<span class="rec-bedrag">\u20AC'+parseFloat(r.bedrag||0).toFixed(2)+'</span>':'';
      h += '<div class="rec-row"><div class="rec-dot '+dotCls+'"></div>';
      h += '<div class="rec-body"><div class="rec-reden">'+esc(r.reden)+'</div>';
      h += '<div class="rec-datum">'+fDate(r.datum)+'</div></div>';
      h += bedrag;
      h += '<button class="rec-del" onclick="doDelRecord(event,\''+p.id+'\','+idx+')" title="Verwijderen">'+I.del+'</button></div>';
    });
  }
  h += '</div>';
  return h;
}

// ── SELECT ZAAK ───────────────────────────────────────────────────────
function selectZaak(id) {
  activeZaakId = id;
  activeId = null;
  var z = findZ(id); if(!z) return;
  renderSidebar();
  closeDrawer();
  showDossier(buildZaakDossier(z));
}

function buildZaakDossier(z) {
  var betP = (z.betrokkenen||[]).map(function(pid){ return findP(pid); }).filter(Boolean);

  var h = '<div class="dos-topbar">';
  h += '<div>';
  h += '<div class="dos-name-row">';
  h += '<div class="dos-name">'+esc(z.titel)+'</div>';
  h += '<button class="icon-btn" onclick="openZaakEdit(\''+z.id+'\')" title="Zaak bewerken">'+I.edit+'</button>';
  h += '</div>';
  h += '<div class="dos-id">Zaak-ID: '+z.id+' &nbsp;&middot;&nbsp; Aangemaakt: '+fDate(z.aangemaakt)+'</div>';
  h += '<div class="dos-chips">'+zaakTypeChip(z)+zaakStatusChip(z)+'</div>';
  h += '</div>';
  h += '<div class="dos-actions">';
  h += '<button class="btn btn-ghost btn-sm" onclick="openZaakEdit(\''+z.id+'\')">'+I.edit+' Bewerken</button>';
  h += '<button class="btn btn-danger btn-sm" onclick="doVerwijderZaak(\''+z.id+'\')">'+I.del+' Verwijder</button>';
  h += '</div></div>';

  if(z.omschrijving) {
    h += '<div class="info-block" style="margin-bottom:1.25rem"><div class="info-label">Omschrijving</div>';
    h += '<div style="font-size:.875rem;color:var(--t1);line-height:1.6;margin-top:4px">'+esc(z.omschrijving)+'</div></div>';
  }

  h += '<div class="section"><div class="section-hdr"><span class="section-title">Betrokkenen ('+betP.length+')</span></div>';
  if(!betP.length) {
    h += '<div class="no-rec">Geen betrokkenen gekoppeld</div>';
  } else {
    betP.forEach(function(p) {
      var s = p.status||'vrij';
      var sCls = s==='opgepakt'?'status-opgepakt':s==='voortvluchtig'?'status-voortvluchtig':'status-vrij';
      h += '<div class="rec-row" style="cursor:pointer" onclick="selectPerson(\''+p.id+'\')">';
      h += '<div class="pr-av" style="width:32px;height:32px;font-size:.65rem;flex-shrink:0">'+initials(p.naam)+'</div>';
      h += '<div class="rec-body"><div class="rec-reden">'+esc(p.naam)+'</div>';
      h += '<div class="rec-datum">'+p.id+(p.nummerplaat?' &middot; '+esc(p.nummerplaat):'')+'</div></div>';
      h += '<div style="display:flex;gap:4px;flex-wrap:wrap">'+chips(p)+'</div>';
      h += '</div>';
    });
  }
  h += '</div>';
  return h;
}

function showDossier(html) {
  document.getElementById('emptyState').style.display = 'none';
  var dw = document.getElementById('dossierWrap');
  dw.style.display = 'block';
  document.getElementById('dossier').innerHTML = html;
}

// ── MODALS ────────────────────────────────────────────────────────────
function openM(id) {
  if(id==='mAdd') {
    document.getElementById('aNaam').value='';
    document.getElementById('aGeb').value='';
    document.getElementById('aNat').value='';
    document.getElementById('aRij').value='geldig';
    document.getElementById('aStatus').value='vrij';
    document.getElementById('aPlaat').value='';
    document.getElementById('aNote').value='';
    document.getElementById('aNaamW').style.display='none';
    document.getElementById(id).classList.add('open');
    setTimeout(function(){ document.getElementById('aNaam').focus(); }, 200);
    return;
  }
  if(id==='mZaak') {
    document.getElementById('zTitel').value='';
    document.getElementById('zType').value='misdrijf';
    document.getElementById('zStatus').value='open';
    document.getElementById('zOmschrijving').value='';
    document.getElementById('zTitelW').style.display='none';
    renderBetrokkenenList('betrokkenenList', []);
    document.getElementById(id).classList.add('open');
    setTimeout(function(){ document.getElementById('zTitel').focus(); }, 200);
    return;
  }
  document.getElementById(id).classList.add('open');
}
function closeM(id) { document.getElementById(id).classList.remove('open'); }

document.querySelectorAll('.overlay').forEach(function(el) {
  el.addEventListener('click', function(e){ if(e.target===el) el.classList.remove('open'); });
});

// ── CONFIRM ───────────────────────────────────────────────────────────
function askConfirm(tekst, cb) { confirmCb=cb; document.getElementById('confirmText').textContent=tekst; document.getElementById('mConfirm').classList.add('open'); }
function confirmJa()  { closeM('mConfirm'); if(confirmCb){ confirmCb(); confirmCb=null; } }
function confirmNee() { closeM('mConfirm'); confirmCb=null; }

// ── ADD PERSON ────────────────────────────────────────────────────────
function doAdd() {
  var naam = document.getElementById('aNaam').value.trim();
  if(!naam){ document.getElementById('aNaamW').style.display='block'; return; }
  document.getElementById('aNaamW').style.display='none';
  var notitie = document.getElementById('aNote').value.trim();
  var plaat = document.getElementById('aPlaat').value.trim().toUpperCase();
  var p = {
    id: uid('P'),
    naam: naam,
    geboortedatum: document.getElementById('aGeb').value,
    nationaliteit: document.getElementById('aNat').value.trim(),
    rijbewijs: document.getElementById('aRij').value,
    status: document.getElementById('aStatus').value,
    nummerplaat: plaat||null,
    aangemaakt: today(),
    records: notitie?[{type:'notitie',reden:notitie,datum:today()}]:[]
  };
  db.push(p); saveDB(); closeM('mAdd'); refreshAll(); selectPerson(p.id);
}

// ── RECORD ────────────────────────────────────────────────────────────
function openRecModal(pid) {
  activePid = pid;
  var p = findP(pid);
  document.getElementById('mRecTitle').textContent = 'Record toevoegen — '+p.naam;
  document.getElementById('rType').value='boete';
  document.getElementById('rReden').value='';
  document.getElementById('rBedrag').value='';
  toggleBedrag();
  document.getElementById('mRec').classList.add('open');
  setTimeout(function(){ document.getElementById('rReden').focus(); }, 200);
}
function toggleBedrag() {
  document.getElementById('rBedragGroup').style.display = document.getElementById('rType').value==='boete'?'flex':'none';
}
function doRec() {
  var reden = document.getElementById('rReden').value.trim();
  if(!reden){ alert('Omschrijving is verplicht'); return; }
  var p = findP(activePid); if(!p) return;
  if(!p.records) p.records=[];
  p.records.push({ type:document.getElementById('rType').value, reden:reden, bedrag:parseFloat(document.getElementById('rBedrag').value)||0, datum:today() });
  saveDB(); closeM('mRec'); refreshAll();
  if(activeId===activePid) showDossier(buildDossier(p));
}
function doDelRecord(evt, pid, idx) {
  evt.stopPropagation();
  var p = findP(pid); if(!p) return;
  var r = p.records[idx];
  askConfirm('Record verwijderen: "'+(r?r.reden:'dit record')+'"?', function(){
    var p2=findP(pid); if(!p2) return;
    p2.records.splice(idx,1);
    saveDB(); refreshAll();
    if(activeId===pid) showDossier(buildDossier(p2));
  });
}

// ── NAAM / RIJ / STATUS / PLAAT BEWERKEN ─────────────────────────────
function openEditNaam(id) {
  activePid=id; var p=findP(id);
  document.getElementById('nNaam').value=p.naam;
  document.getElementById('nNaamW').style.display='none';
  document.getElementById('mNaam').classList.add('open');
  setTimeout(function(){ document.getElementById('nNaam').focus(); },200);
}
function doNaam() {
  var naam=document.getElementById('nNaam').value.trim();
  if(!naam){ document.getElementById('nNaamW').style.display='block'; return; }
  var p=findP(activePid); if(!p) return;
  p.naam=naam; saveDB(); closeM('mNaam'); refreshAll();
  if(activeId===activePid) showDossier(buildDossier(p));
}
function openEditRij(id) {
  activePid=id; var p=findP(id);
  document.getElementById('rijStatus').value=p.rijbewijs||'geldig';
  document.getElementById('mRij').classList.add('open');
}
function doRij() {
  var p=findP(activePid); if(!p) return;
  p.rijbewijs=document.getElementById('rijStatus').value;
  saveDB(); closeM('mRij'); refreshAll();
  if(activeId===activePid) showDossier(buildDossier(p));
